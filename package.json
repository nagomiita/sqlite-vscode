{
  "name": "sqlite-vscode",
  "displayName": "SQLite Vscode",
  "description": "Quick read-only SQLite viewer for VS Code with a virtualized table UI and a read-only SQL runner.",
  "version": "0.0.1",
  "publisher": "nagomiita",
  "private": true,
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nagomiita/sqlite-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/nagomiita/sqlite-vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "sqlite",
    "db",
    "database",
    "viewer"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "sqliteVscode.viewer",
        "displayName": "SQLite Vscode",
        "selector": [
          {
            "filenamePattern": "*.db"
          },
          {
            "filenamePattern": "*.sqlite"
          },
          {
            "filenamePattern": "*.sqlite3"
          },
          {
            "filenamePattern": "*.db3"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "SQLite Vscode",
      "properties": {
        "sqliteVscode.labelsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to a JSON file mapping physical table/column names to logical (human-readable) names. Absolute, or relative to the database file. When empty, a sibling `<dbFileName>.labels.json` is used if present."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "icon": "node scripts/make-icon.mjs",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wa-sqlite": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.3"
  }
}
